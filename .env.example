# Required: Get from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789

# Required: Your phone number with country code
TELEGRAM_PHONE=+1234567890

# Optional: Paths (defaults shown)
TELEGRAM_SESSION_PATH=telegram.session
TOKENIZER_PATH=tokenizer.json

# Optional: Ollama configuration (defaults shown)
OLLAMA_URL=http://172.17.0.1:11434
OLLAMA_MODEL=qwen3.5-custom
